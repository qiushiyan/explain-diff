{
  "name": "explain-diff",
  "version": "0.1.0",
  "description": "Literate diff explainers with quizzes, built for terminal coding agents",
  "license": "MIT",
  "author": "qiushiyan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qiushiyan/explain-diff.git"
  },
  "homepage": "https://github.com/qiushiyan/explain-diff#readme",
  "bugs": "https://github.com/qiushiyan/explain-diff/issues",
  "keywords": [
    "diff",
    "code-review",
    "claude-code",
    "coding-agent",
    "skill",
    "quiz",
    "literate"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "explain-diff": "dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm build:cli && pnpm build:viewer",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:viewer": "vite build",
    "dev:viewer": "vite",
    "typecheck": "tsc -p tsconfig.cli.json --noEmit && tsc -p tsconfig.viewer.json",
    "link:global": "pnpm add -g link:.",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@pierre/diffs": "^1.2.12",
    "@pierre/trees": "1.0.0-beta.5",
    "commander": "^15.0.0",
    "marked": "^18.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "playwright-core": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
